<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F7FA"
    tools:context=".screens.InfoCarActivity">

    <TextView
        android:id="@+id/tv_add_car"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/round_font"
        android:gravity="center"
        android:text="יצירת רכב"
        android:textColor="#0B4F86"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_add_car">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9DAFFAFA"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <EditText
                    android:id="@+id/et_add_car_type"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="🚘 סוג רכב"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/sp_add_car_rank"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext" />

                <EditText
                    android:id="@+id/et_add_car_number"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="🔢 מספר רכב"
                    android:inputType="number"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_add_car_insurance_date"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:clickable="true"
                    android:focusable="false"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="🛡️ תאריך ביטוח אחרון"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/et_add_car_license_car_date"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/rounded_edittext"
                    android:clickable="true"
                    android:focusable="false"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="📄 רישיון רכב אחרון"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_car_submit"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#388FC3"
                    android:fontFamily="@font/round_font"
                    android:text=" הוספת רכב ➕"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:elevation="6dp" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>