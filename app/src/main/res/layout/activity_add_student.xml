<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F7FA"
    tools:context=".screens.AddStudentActivity">

    <TextView
        android:id="@+id/addStudentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/round_font"
        android:gravity="center"
        android:text="הוספת תלמיד"
        android:textColor="#0B4F86"
        android:textSize="36sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="32dp"
        app:cardElevation="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/addStudentTitle">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9DAFFAFA"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- שם התלמיד -->
                <EditText
                    android:id="@+id/studentName"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:drawableEnd="@drawable/ic_user"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="שם התלמיד"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- תאריך לידה -->
                <EditText
                    android:id="@+id/studentBirth"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:drawableEnd="@drawable/ic_calendar"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="תאריך לידה"
                    android:inputType="date"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- כתובת מגורים -->
                <EditText
                    android:id="@+id/studentAddress"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:drawableEnd="@drawable/ic_location"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="כתובת מגורים"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- מספר טלפון -->
                <EditText
                    android:id="@+id/studentPhone"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/rounded_edittext"
                    android:drawableEnd="@drawable/ic_phone"
                    android:drawablePadding="12dp"
                    android:fontFamily="@font/round_font"
                    android:gravity="right|center_vertical"
                    android:hint="מספר טלפון"
                    android:inputType="phone"
                    android:paddingHorizontal="20dp"
                    android:textColor="#0B4F86"
                    android:textColorHint="#0B4F86"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- סיסמה עם עין לחשיפה -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxBackgroundMode="none"
                    app:hintEnabled="false"
                    app:passwordToggleEnabled="true"
                    app:passwordToggleTint="#0B4F86">

                    <EditText
                        android:id="@+id/studentPassword"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/rounded_edittext"
                        android:drawableEnd="@drawable/ic_lock"
                        android:drawablePadding="12dp"
                        android:fontFamily="@font/round_font"
                        android:gravity="right|center_vertical"
                        android:hint="קבע סיסמא לתלמיד"
                        android:inputType="numberPassword"
                        android:paddingHorizontal="20dp"
                        android:textColor="#0B4F86"
                        android:textColorHint="#0B4F86"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- אזור הסטטוסים (Switches) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="16dp"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTheory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/round_font"
                        android:text=" עבר תיאוריה ✅"
                        android:textColor="#0B4F86"
                        android:textDirection="rtl"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEyes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/round_font"
                        android:text=" בדיקת עיניים 👁"
                        android:textColor="#0B4F86"
                        android:textDirection="rtl"
                        android:textStyle="bold" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchHealth"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/round_font"
                        android:text=" הצהרת בריאות 📜"
                        android:textColor="#0B4F86"
                        android:textDirection="rtl"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- כפתור הוספה -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_AddStudent"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:backgroundTint="#388FC3"
                    android:fontFamily="@font/round_font"
                    android:text="הוספת תלמיד"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:cornerRadius="30dp"
                    app:elevation="4dp" />

            </LinearLayout>
        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>