<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E0F7FA"
    tools:context=".screens.ImStudentActivity">

    <!-- כותרת עליונה מרשימה -->
    <TextView
        android:id="@+id/tv_im_student"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:fontFamily="@font/round_font"
        android:text="דף תלמיד אישי"
        android:textColor="#0B4F86"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/signoutStudent"
        app:layout_constraintTop_toBottomOf="@+id/tv_im_student">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- כרטיס פרופיל ראשי -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#9DAFFAFA"
                app:cardCornerRadius="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/tv_student_name_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="שלום, ישראל ישראלי"
                        android:textColor="#0B4F86"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_teacher_name_display"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="מורה נהיגה: אבי לוי"
                        android:textColor="#546E7A"
                        android:textSize="16sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- כרטיס פרטים אישיים -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#9DAFFAFA"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="פרטים אישיים"
                        android:textColor="#0B4F86"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_student_phone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📞 טלפון: -" />

                    <TextView
                        android:id="@+id/tv_student_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📍 כתובת: -" />

                    <TextView
                        android:id="@+id/tv_student_birthdate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📅 תאריך לידה: -" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="8dp"
                        android:background="#E0E0E0" />

                    <TextView
                        android:id="@+id/tv_student_theory"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="📝 תיאוריה: -" />

                    <TextView
                        android:id="@+id/tv_student_eyes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:text="👁️ בדיקת עיניים: -" />

                    <TextView
                        android:id="@+id/tv_student_health"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🏥 הצהרת בריאות: -" />


                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ציר זמן סטטוס למידה -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:layoutDirection="rtl"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/status_process"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_inactive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="בתהליך"
                    android:textColor="#FFFFFF" />

                <View
                    android:layout_width="30dp"
                    android:layout_height="2dp"
                    android:background="#0B4F86" />

                <TextView
                    android:id="@+id/status_test"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_inactive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="בטסט"
                    android:textColor="#FFFFFF" />

                <View
                    android:layout_width="30dp"
                    android:layout_height="2dp"
                    android:background="#0B4F86" />

                <TextView
                    android:id="@+id/status_passed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_status_inactive"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="עבר"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <!-- שיעורים עתידיים -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_marginTop="24dp"
                android:text="שיעורים עתידיים"
                android:textColor="#0B4F86"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_future_lessons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_no_future_lessons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="אין עדיין שיעורים עתידיים"
                android:textColor="#757575"
                android:visibility="gone" />

            <!-- שיעורים שהסתיימו -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="right"
                android:layout_marginTop="24dp"
                android:text="שיעורים שהסתיימו"
                android:textColor="#0B4F86"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_past_lessons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tv_no_past_lessons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="אין עדיין שיעורים שהסתיימו"
                android:textColor="#757575"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/signoutStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#388FC3"
        android:fontFamily="@font/round_font"
        android:text="התנתקות"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>